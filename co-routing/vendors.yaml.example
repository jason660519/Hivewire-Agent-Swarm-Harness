# Hivewire co-routing — vendor adapter templates
#
# This is the "plug a proxy vendor in with one config block" artifact.
# Copy the block you need into your pools.yaml, fill in the credentials, done —
# no code change. That is the whole pitch to a residential-proxy vendor: their
# product becomes a Route Profile field, usable from any AG-UI / MCP runtime.
#
# How templating works (see server.py: resolve_proxy_url):
#   {region}      <- RouteProfile.region, passed through verbatim. Use the
#                    country/region code THIS vendor expects (e.g. "us", "gb"),
#                    not a freeform label.
#   {session_id}  <- generated per request. session_policy=sticky reuses one id
#                    (same IP for the session); rotating gets a fresh id (new IP).
#
# IMPORTANT: most grammars below follow each vendor's common public pattern but
# are UNVERIFIED — exact field names/separators differ per plan and change over
# time. Confirm against the vendor's dashboard/docs before prod. proxy-cheap is
# the exception: its block is VERIFIED end-to-end (see docs/vendor-integration.md).

pools:

  # --- proxy-cheap (residential) — VERIFIED 2026-06-22 --------------------
  # proxy-cheap encodes options in the PASSWORD suffix (not the username), and
  # one base credential serves rotating + sticky + geo:
  #   _country-<cc>     geo-lock          _session-<id>   sticky (same id = same IP)
  # With session_policy=rotating the harness feeds a fresh {session_id} each
  # request (-> new IP); sticky reuses one (-> held IP). HTTP-only; the gateway
  # CONNECT-tunnels https targets. Connection host/port come from the dashboard's
  # "Setup Credentials" (the REST API does not return them).
  proxycheap-residential:
    region: us                # country code, e.g. us / de / gb
    mock: false
    proxy_template: "http://USERNAME:PASSWORD_country-{region}_session-{session_id}@thehub.proxy-cheap.com:8080"

  # --- anyIP (residential) -------------------------------------------------
  # Exact rotation/session/auth grammar still TBD until their docs are reviewed.
  # This is a starting template, not a verified format.
  anyip-residential:
    region: us
    mock: false
    proxy_template: "http://USERNAME-country-{region}-session-{session_id}:PASSWORD@gw.anyip.example:8080"

  # --- Bright Data (residential zone) -------------------------------------
  brightdata-residential:
    region: us
    mock: false
    proxy_template: "http://brd-customer-CUSTOMER_ID-zone-ZONE-country-{region}-session-{session_id}:PASSWORD@brd.superproxy.io:22225"

  # --- Oxylabs (residential) ----------------------------------------------
  oxylabs-residential:
    region: us
    mock: false
    proxy_template: "http://customer-USERNAME-cc-{region}-sessid-{session_id}:PASSWORD@pr.oxylabs.io:7777"

  # --- Smartproxy / Decodo (residential) ----------------------------------
  smartproxy-residential:
    region: us
    mock: false
    proxy_template: "http://user-USERNAME-country-{region}-session-{session_id}:PASSWORD@gate.smartproxy.com:7000"

  # --- Single fixed proxy (no per-request region/session) ------------------
  # For datacenter proxies or gateways that don't encode region in the user.
  fixed-gateway:
    region: us
    mock: false
    proxy_url: "http://USERNAME:PASSWORD@gateway.example:8080"
