# Hivewire egress benchmark — track config (follows METHODOLOGY.md)
#
# Copy to benchmark/targets.yaml and edit. Runs against the built-in MOCK pools
# by default (direct connections, no credentials) so you can validate plumbing
# today. When real credentials land:
#   1. Add real pools to pools.yaml (see vendors.yaml.example).
#   2. Swap each `pool:` below to the real pool for that vendor+product.
#   3. Raise runs_per_target to >=20 (see METHODOLOGY.md §4) and re-run.
#
# Each target_class is run with the comparable product on BOTH vendors, against
# the SAME targets, so every comparison is apples-to-apples (METHODOLOGY.md §2).

runs_per_target: 5      # quick offline check; METHODOLOGY.md §4 says >=20 for a real run
concurrency: 5
timeout_s: 25

tracks:
  # ============================ high-volume ============================
  # anyIP rotating mixed res/mobile  vs  proxy-cheap residential rotating
  - name: high-volume-anyip
    vendor: anyip
    pool: mock-us-west          # -> anyIP rotating pool
    region: us
    session_policy: rotating
    target_class: high-volume
    ip_echo: true
    targets: &high_volume_targets
      - "https://api.ipify.org?format=json"   # Tier A: IP echo / calibration
      - "https://httpbin.org/get"             # Tier A
      - "http://books.toscrape.com/"          # Tier B: scraping sandbox (no ToS issue)
      - "http://quotes.toscrape.com/"         # Tier B

  - name: high-volume-control
    vendor: proxy-cheap
    pool: mock-us-west          # -> proxy-cheap residential rotating pool
    region: us
    session_policy: rotating
    target_class: high-volume
    ip_echo: true
    targets: *high_volume_targets

  # ================================ geo ================================
  # anyIP residential + country lock  vs  proxy-cheap residential + country
  - name: geo-anyip
    vendor: anyip
    pool: mock-eu               # -> anyIP residential pool
    region: de
    session_policy: rotating
    target_class: geo
    ip_echo: true
    targets: &geo_targets
      - "https://api.ipify.org?format=json"   # observed_ip -> geolocate in analysis
      - "https://httpbin.org/ip"

  - name: geo-control
    vendor: proxy-cheap
    pool: mock-eu               # -> proxy-cheap residential pool
    region: de
    session_policy: rotating
    target_class: geo
    ip_echo: true
    targets: *geo_targets

  # ============================= high-trust ============================
  # anyIP mobile + sticky  vs  proxy-cheap mobile/sticky
  # Tier A only for now — no commercial anti-bot target is baked in (see
  # METHODOLOGY.md §3 Tier C). Labelled "infra-only" until a ToS-checked
  # anti-bot target is added to the Change log.
  - name: high-trust-anyip
    vendor: anyip
    pool: mock-asia             # -> anyIP mobile pool
    region: jp
    session_policy: sticky
    target_class: high-trust
    ip_echo: true
    targets: &high_trust_targets
      - "https://api.ipify.org?format=json"
      - "https://httpbin.org/headers"

  - name: high-trust-control
    vendor: proxy-cheap
    pool: mock-asia             # -> proxy-cheap mobile/sticky pool
    region: jp
    session_policy: sticky
    target_class: high-trust
    ip_echo: true
    targets: *high_trust_targets
