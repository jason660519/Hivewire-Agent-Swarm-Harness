# Hivewire co-routing — egress pool config
# Copy to pools.yaml and fill in real proxy credentials.
# Pools with mock: true make direct connections (clearly labeled in response metadata).
# Without this file, the built-in mock pools (mock-us-west, mock-asia, mock-eu) are used.
#
# Three pool flavors:
#   mock: true        -> direct connection, no proxy (offline demo).
#   proxy_template    -> vendor adapter; {region} + {session_id} substituted per
#                        request. See vendors.yaml.example for ready-to-fill
#                        templates (anyIP, Bright Data, Oxylabs, Smartproxy, ...).
#   proxy_url         -> a single fixed upstream proxy, no per-request variation.

pools:
  mock-us-west:
    region: us-west
    mock: true

  mock-asia:
    region: asia
    mock: true

  mock-eu:
    region: eu
    mock: true

  # Vendor adapter (preferred for residential proxies) — one pool serves every
  # region/session the caller asks for. {region} <- RouteProfile.region,
  # {session_id} <- generated per request (sticky reuses it, rotating refreshes).
  # See vendors.yaml.example for per-vendor username grammars.
  #
  # anyip-residential:
  #   mock: false
  #   proxy_template: "http://USERNAME-country-{region}-session-{session_id}:PASSWORD@gw.anyip.example:8080"
  #
  # Fixed single proxy (no region/session encoding):
  #
  # fixed-gateway:
  #   mock: false
  #   proxy_url: "http://USERNAME:PASSWORD@proxy.example:8080"
